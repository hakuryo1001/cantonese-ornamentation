% cantonese-flora.sty — full-colour flora ornaments from source PNGs
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cantonese-flora}[2026/06/10 v0.1 Cantonese flora (raster)]

\RequirePackage{graphicx}
\RequirePackage{tikz}
\RequirePackage{pgfkeys}

\graphicspath{{cantonese-pgfornament/assets/flora/}}

\makeatletter
\pgfkeys{
  /cantoneseflora/.cd,
  width/.store in=\cantoneseflora@width,
  width=2cm,
  symmetry/.is choice,
  symmetry/none/.code={\def\cantoneseflora@scalex{1}\def\cantoneseflora@scaley{1}},
  symmetry/v/.code={\def\cantoneseflora@scalex{-1}\def\cantoneseflora@scaley{1}},
  symmetry/h/.code={\def\cantoneseflora@scalex{1}\def\cantoneseflora@scaley{-1}},
  symmetry/c/.code={\def\cantoneseflora@scalex{-1}\def\cantoneseflora@scaley{-1}},
  symmetry=none,
}

% All ornament IDs currently in generic/cantonese/
\newcommand{\cantoneseornamentids}{101,102,103,104,105,106}

\newcommand{\cantonesefloraplate}[3][2.2cm]{%
  \begin{minipage}[t]{3.4cm}
    \centering
    \cantonesefloraornament[width=#1]{#2}\\[0.35em]
    {\small\sffamily\bfseries #2}\\[-0.05em]
    {\footnotesize #3}
  \end{minipage}%
}

\newcommand{\cantonesepgfplate}[3][2.2cm]{%
  \begin{minipage}[t]{3.4cm}
    \centering
    \begin{newfamily}[cantonese]
      \cantoneseornament[width=#1, color=Maroon]{#2}%
    \end{newfamily}\\[0.35em]
    {\small\sffamily\bfseries #2}\\[-0.05em]
    {\footnotesize #3}
  \end{minipage}%
}

\newcommand{\cantonesefloraornament}[2][]{%
  \pgfkeys{/cantoneseflora/.cd, #1}%
  \begin{tikzpicture}
    \begin{scope}[xscale=\cantoneseflora@scalex, yscale=\cantoneseflora@scaley]
      \node[inner sep=0pt] {%
        \includegraphics[width=\cantoneseflora@width]{flora#2.png}};
    \end{scope}
  \end{tikzpicture}%
}

\newcommand{\cantonesefloraornamentview}[1]{%
\begin{newfamily}[cantonese]
\foreach \n in {#1} {%
\begin{tikzpicture}
  \adjustpgfornamentDim{\n}
  \ifdim\pgfcoeff pt >1 pt \relax \def\adjustXY{2}
  \else
  \pgfmathsetmacro{\adjustXY}{2*\pgfcoeff}
  \fi
  \draw[Maroon](-1.25cm,-1.25cm) rectangle (1.25cm,1.25cm);
  \node[inner sep=0pt] (element) {%
    \includegraphics[width=\adjustXY cm]{flora\n.png}};
  \node[anchor=north west,inner sep=0pt,font=\small\bfseries\sffamily,color=red]
    at (2.05cm,1.05cm) {\n};
  \node[anchor=west,text width=4em,font=\footnotesize] at (1.85cm,0) {%
    \getpgfornamentDim{\n}};
\end{tikzpicture}%
\space\space\space\space}
\end{newfamily}}
\makeatother

\endinput
